# ============================================================
# MAJI — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- CHOIX DU PROVIDER IA (Vision) ---
# Option A : Google Gemini Flash (GRATUIT, recommandé pour débuter)
#   → Obtenir la clé sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option B : OpenAI GPT-4o (payant, meilleure qualité)
#   → Obtenir la clé sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Note : si les deux clés sont renseignées, Gemini est prioritaire

# --- Paramètres métier (modifiables selon les tarifs réels) ---
DEFAULT_MARGIN_RATE=0.30
MACHINE_HOURLY_RATE=85.0
OPERATOR_HOURLY_RATE=35.0

# --- OCR ---
OCR_CONFIDENCE_THRESHOLD=0.7
