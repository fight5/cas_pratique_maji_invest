# Clé API OpenAI (obligatoire)
OPENAI_API_KEY=sk-...

# Modèle Vision IA (gpt-4o recommandé)
OPENAI_MODEL=gpt-4o

# Paramètres métier (modifiables selon les tarifs réels)
DEFAULT_MARGIN_RATE=0.30
MACHINE_HOURLY_RATE=85.0
OPERATOR_HOURLY_RATE=35.0

# Seuil de confiance OCR (0.0 à 1.0)
OCR_CONFIDENCE_THRESHOLD=0.7

# Taille max image (px, côté le plus court)
MAX_IMAGE_SIZE=4096
